  window._lastResult = d;
}

function escHtml(s) {
  if (!s) return '';
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function decodeAnother() {
  document.getElementById('brandInput').value = '';
  document.getElementById('contextInput').value = '';
  document.getElementById('resultsZone').classList.remove('active');
  document.getElementById('resultsZone').innerHTML = '';
  document.getElementById('brandInput').focus();
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function saveReport() {
  if (!window._lastResult) return;
  const d = window._lastResult;
  const lines = [
    `BRAND DECODER — ${d.brand.toUpperCase()}`,
    `${'='.repeat(50)}`,
    `Category: ${d.category}`,
    `Overall Signal: ${d.overallSignal.toUpperCase()}`,
    `Signal: ${d.signalReason}`,
    ``,
    `WHITE SPACE: ${d.whiteSpace?.gapTitle}`,
    d.whiteSpace?.gapDescription,
    `How to own: ${d.whiteSpace?.howToOwn}`,
    ``,
    `WHAT THEY DO`,
    `Offering: ${d.what?.coreOffering}`,
    `Positioning: ${d.what?.positioningStatement}`,
    ``,
    `VISUAL (${d.visual?.overall})`,
    `Color: ${d.visual?.palette}`,
    `Type: ${d.visual?.typography}`,
    `Standout: ${d.visual?.standoutElement}`,
    `Weakness: ${d.visual?.weakness}`,
    ``,
    `VERBAL (${d.verbal?.overall})`,
    `Tone: ${d.verbal?.tone}`,
    `What they never say: ${d.verbal?.whatTheyNeverSay}`,
    ``,
    `CONTRADICTIONS`,
    ...(d.contradictions || []).map((c,i) => `${i+1}. ${c}`),
    ``,
    `VERDICT: "${d.verdictLine}"`,
    ``,
    `Decoded by Brand Decoder — ${new Date().toLocaleDateString()}`
  ].join('\n');

  const blob = new Blob([lines], { type: 'text/plain' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `${d.brand.toLowerCase().replace(/\s+/g,'-')}-brand-decode.txt`;
  a.click();
  URL.revokeObjectURL(url);
}

// Enter key support
document.addEventListener('DOMContentLoaded', () => {
  init();
  document.getElementById('brandInput').addEventListener('keydown', e => {
    if (e.key === 'Enter') runDecode();
  });
});
</script>

